# Set true only when you want sample local fixtures rather than the free ESPN score feed.
DEMO_MODE=false
CORS_ORIGINS=http://touchline26.localhost:3026

# No API key is required in this version.
# Current World Cup scores/schedule: ESPN public scoreboard feed (portfolio/local use).
# Historical 2018 + 2022 player event data: StatsBomb Open Data.

# Live match behaviour
# Match Desk and a live Match Center refresh from the local backend every 5 seconds.
# The backend polls ESPN every 5 seconds only around live/near-kickoff fixtures.
ESPN_LIVE_POLL_SECONDS=5
ESPN_IDLE_POLL_SECONDS=45
ESPN_SUMMARY_CACHE_SECONDS=8
